{
  "name": "gitsage",
  "version": "1.0.0",
  "description": "AI-powered Git companion that understands your code",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "gitsage": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "release": "semantic-release"
  },
  "keywords": [
    "git",
    "ai",
    "cli",
    "developer-tools"
  ],
  "author": "GitSage Team",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "conf": "^13.0.1",
    "inquirer": "^9.2.23",
    "node-fetch": "^3.3.2",
    "ora": "^8.0.1",
    "simple-git": "^3.24.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^20.11.19",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.2",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.3",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  },
  "tsup": {
    "entry": [
      "src/index.ts"
    ],
    "format": [
      "esm"
    ],
    "platform": "node",
    "target": "node18",
    "clean": true,
    "shims": true
  }
}
